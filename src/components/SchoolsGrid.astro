---
import { getCollection } from 'astro:content';

const schools = await getCollection('schools');
const marseille = schools.filter(s => s.data.city === 'marseille');
const nice = schools.filter(s => s.data.city === 'nice');
const all = [...marseille, ...nice];
---
<div class="schools-section">
  <div class="pill-filters">
    <button class="pill active" data-filter="all">Toutes les villes</button>
    <button class="pill" data-filter="marseille">Marseille</button>
    <button class="pill" data-filter="nice">Nice</button>
  </div>

  <div class="schools-grid" id="schools-grid">
    {all.map((school) => (
      <a
        href={school.data.site}
        target="_blank"
        rel="noopener"
        class="school-card"
        data-city={school.data.city}
      >
        <div class="school-card-header">
          <span class={`city-dot dot--${school.data.city}`}></span>
          <span class="city-label">{school.data.city === 'marseille' ? 'Marseille' : 'Nice'}</span>
        </div>
        <div class="school-name">{school.data.name}</div>
        <div class="school-desc">{school.data.description}</div>
        <span class="school-link">Voir le site →</span>
      </a>
    ))}
  </div>
</div>

<style>
.schools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 0.5px solid var(--gray-border);
  border-radius: 8px;
  overflow: hidden;
}

.school-card {
  display: flex;
  flex-direction: column;
  padding: 1.25rem;
  background: #fff;
  border-right: 0.5px solid var(--gray-border);
  border-bottom: 0.5px solid var(--gray-border);
  text-decoration: none;
  transition: background 0.12s;
  cursor: pointer;
}

.school-card:hover {
  background: var(--b50);
}

.school-card:nth-child(3n) {
  border-right: none;
}

.school-card-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.city-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot--marseille {
  background: var(--b400);
}

.dot--nice {
  background: var(--b200);
}

.city-label {
  font-size: 11px;
  font-weight: 500;
  color: var(--b600);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.school-name {
  font-size: 15px;
  font-weight: 500;
  color: var(--b900);
  margin-bottom: 0.5rem;
  line-height: 1.3;
}

.school-desc {
  font-size: 13px;
  color: var(--gray-secondary);
  line-height: 1.5;
  flex: 1;
  margin-bottom: 0.75rem;
}

.school-link {
  font-size: 12px;
  color: var(--b600);
  font-weight: 400;
}

@media (max-width: 768px) {
  .schools-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .school-card:nth-child(3n) {
    border-right: 0.5px solid var(--gray-border);
  }
  .school-card:nth-child(2n) {
    border-right: none;
  }
}

@media (max-width: 480px) {
  .schools-grid {
    grid-template-columns: 1fr;
  }
  .school-card {
    border-right: none;
  }
}
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.pill-filters .pill');
  const cards = document.querySelectorAll<HTMLElement>('.school-card');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');

      const filter = pill.dataset.filter;
      cards.forEach(card => {
        if (filter === 'all' || card.dataset.city === filter) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
