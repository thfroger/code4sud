---
import { getCollection } from 'astro:content';

interface Props {
  limit?: number;
  showAll?: boolean;
}

const { limit = 4, showAll = false } = Astro.props;

const allEvents = await getCollection('events');
const sorted = allEvents.sort((a, b) => {
  if (!showAll) {
    if (a.data.status === 'a-venir' && b.data.status !== 'a-venir') return -1;
    if (b.data.status === 'a-venir' && a.data.status !== 'a-venir') return 1;
  }
  return b.data.date.getTime() - a.data.date.getTime();
});
const events = showAll ? sorted : sorted.slice(0, limit);

const typeLabels: Record<string, string> = {
  hackathon: 'Hackathon',
  jobdating: 'Job dating',
  'talent-day': 'Talent day',
  atelier: 'Atelier',
};

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);
}
---
<div class="events-list">
  {events.map((event) => (
    <a href={`/evenements/${event.slug}`} class="event-row">
      <div class="event-date">{formatDate(event.data.date)}</div>
      <div class="event-main">
        <div class="event-type">{typeLabels[event.data.type] || event.data.type}</div>
        <div class="event-title">{event.data.title}</div>
        <div class="event-location">{event.data.location}</div>
      </div>
      <div class="event-aside">
        {event.data.status === 'a-venir' && (
          <span class="badge-upcoming">À venir</span>
        )}
        <span class="event-arrow">→</span>
      </div>
    </a>
  ))}
</div>

<style>
.events-list {
  border-top: 0.5px solid var(--gray-border);
}

.event-row {
  display: grid;
  grid-template-columns: 90px 1fr auto;
  align-items: center;
  gap: 1.25rem;
  padding: 1rem 0;
  border-bottom: 0.5px solid var(--gray-border);
  text-decoration: none;
  color: inherit;
  cursor: pointer;
  transition: background 0.12s;
  margin: 0 -1rem;
  padding-left: 1rem;
  padding-right: 1rem;
  border-radius: 4px;
}

.event-row:hover {
  background: var(--b50);
}

.event-row:hover .event-title {
  color: var(--b600);
}

.event-row:hover .event-arrow {
  transform: translateX(3px);
}

.event-arrow {
  transition: transform 0.12s;
}

.event-date {
  font-size: 13px;
  color: var(--gray-secondary);
  line-height: 1.4;
}

.event-type {
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--b600);
  font-weight: 400;
  margin-bottom: 0.2rem;
}

.event-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--b900);
  line-height: 1.3;
}

.event-location {
  font-size: 12px;
  color: var(--gray-secondary);
  margin-top: 0.2rem;
}

.event-aside {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 0.4rem;
}

.badge-upcoming {
  font-size: 11px;
  font-weight: 400;
  color: var(--b800);
  background: var(--b50);
  border: 1px solid var(--b100);
  border-radius: 100px;
  padding: 0.2rem 0.6rem;
  white-space: nowrap;
}

.event-arrow {
  color: var(--b400);
  font-size: 16px;
}

@media (max-width: 480px) {
  .event-row {
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
  }
  .event-date {
    display: none;
  }
}
</style>
