---
import { getCollection } from 'astro:content';

interface Props {
  limit?: number;
  showFilters?: boolean;
}

const { limit = 4, showFilters = false } = Astro.props;

const allReals = await getCollection('realisations');
const sorted = allReals.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const reals = limit > 0 ? sorted.slice(0, limit) : sorted;

const featured = reals.find(r => r.data.featured);
const others = reals.filter(r => !r.data.featured);

const typeLabels: Record<string, string> = {
  hackathon: 'Hackathon',
  application: 'Application',
  evenement: 'Événement',
  formation: 'Formation',
};

function formatYear(date: Date) {
  return date.getFullYear().toString();
}
---
{showFilters && (
  <div class="pill-filters" id="real-filters">
    <button class="pill active" data-filter="all">Tous</button>
    <button class="pill" data-filter="hackathon">Hackathon</button>
    <button class="pill" data-filter="application">Application</button>
    <button class="pill" data-filter="evenement">Événement</button>
    <button class="pill" data-filter="formation">Formation</button>
  </div>
)}

<div class="reals-grid" id="reals-grid">
  {featured && (
    <a href={`/realisations`} class="real-card real-card--featured" data-type={featured.data.type}>
      <div class="real-type featured-type">{typeLabels[featured.data.type]}</div>
      <div class="real-title featured-title">{featured.data.title}</div>
      <div class="real-desc featured-desc">{featured.data.description}</div>
      <div class="real-meta featured-meta">{formatYear(featured.data.date)}</div>
    </a>
  )}
  {others.slice(0, 3).map((real) => (
    <a href={`/realisations`} class="real-card" data-type={real.data.type}>
      <div class="real-type">{typeLabels[real.data.type]}</div>
      <div class="real-title">{real.data.title}</div>
      <div class="real-desc-short">{real.data.description}</div>
      <div class="real-meta">{formatYear(real.data.date)}</div>
    </a>
  ))}
</div>

{showFilters && (
  <script>
    const filterBtns = document.querySelectorAll<HTMLButtonElement>('#real-filters .pill');
    const realCards = document.querySelectorAll<HTMLElement>('#reals-grid .real-card');

    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = btn.dataset.filter;
        realCards.forEach(card => {
          card.style.display = (filter === 'all' || card.dataset.type === filter) ? '' : 'none';
        });
      });
    });
  </script>
)}

<style>
.reals-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: 1px;
  background: var(--gray-border);
  border: 0.5px solid var(--gray-border);
  border-radius: 8px;
  overflow: hidden;
}

.real-card {
  display: flex;
  flex-direction: column;
  padding: 1.5rem;
  text-decoration: none;
  transition: background 0.12s;
  background: #fff;
}

.real-card--featured {
  grid-row: 1 / 3;
  background: var(--b800);
}

.real-card--featured:hover {
  background: var(--b900);
}

.real-card:not(.real-card--featured):hover {
  background: var(--b50);
}

.real-type {
  font-size: 10px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--b600);
  font-weight: 400;
  margin-bottom: 0.5rem;
}

.featured-type {
  color: var(--b200);
}

.real-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--b900);
  line-height: 1.3;
  margin-bottom: 0.5rem;
}

.featured-title {
  font-size: 19px;
  color: #fff;
  flex: 1;
}

.real-desc {
  font-size: 13px;
  color: var(--b100);
  line-height: 1.55;
  flex: 1;
  margin-bottom: 1rem;
}

.real-desc-short {
  font-size: 13px;
  color: var(--gray-secondary);
  line-height: 1.5;
  flex: 1;
  margin-bottom: 0.5rem;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.real-meta {
  font-size: 12px;
  color: var(--b600);
  font-weight: 400;
}

.featured-meta {
  color: var(--b200);
}

@media (max-width: 640px) {
  .reals-grid {
    grid-template-columns: 1fr;
  }
  .real-card--featured {
    grid-row: auto;
  }
}
</style>
