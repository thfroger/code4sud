---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allEvents = await getCollection('events');
const events = allEvents.sort((a, b) => {
  if (a.data.status === 'a-venir' && b.data.status !== 'a-venir') return -1;
  if (b.data.status === 'a-venir' && a.data.status !== 'a-venir') return 1;
  return b.data.date.getTime() - a.data.date.getTime();
});

const typeLabels: Record<string, string> = {
  hackathon: 'Hackathon',
  jobdating: 'Job dating',
  'talent-day': 'Talent day',
  atelier: 'Atelier',
};

function formatDate(date: Date) {
  return new Intl.DateTimeFormat('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' }).format(date);
}
---
<Base title="Événements" description="Tous les événements organisés par Code4Sud depuis 2018 — hackathons, job datings, ateliers.">
  <div class="page-hero">
    <div class="container">
      <div class="hero-tag">
        <span class="tag-line"></span>
        Depuis 2018
      </div>
      <h1>Événements</h1>
      <p>Hackathon, job dating, talent days et ateliers organisés par le réseau Code4Sud en région Sud.</p>
    </div>
  </div>

  <section class="page-section">
    <div class="container">
      <div class="pill-filters" id="event-filters">
        <button class="pill active" data-filter="all">Tous</button>
        <button class="pill" data-filter="hackathon">Hackathon</button>
        <button class="pill" data-filter="jobdating">Job dating</button>
        <button class="pill" data-filter="talent-day">Talent day</button>
        <button class="pill" data-filter="atelier">Atelier</button>
      </div>

      <div class="events-list" id="events-list">
        {events.map((event) => (
          <a
            href={`/evenements/${event.slug}`}
            class="event-row"
            data-types={event.data.type.join(',')}
          >
            <div class="event-date">{formatDate(event.data.date)}</div>
            <div class="event-main">
              <div class="event-type">{event.data.type.map(t => typeLabels[t] || t).join(' · ')}</div>
              <div class="event-title">{event.data.title}</div>
              <div class="event-location">{event.data.location}</div>
            </div>
            <div class="event-aside">
              {event.data.status === 'a-venir' && (
                <span class="badge-upcoming">À venir</span>
              )}
              <span class="event-arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
.page-hero {
  background: var(--b900);
  padding: 3.5rem 0 3rem;
}
.hero-tag {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--b200);
  font-size: 13px;
  margin-bottom: 1rem;
}
.tag-line { width: 24px; height: 1px; background: var(--b200); }
.page-hero h1 {
  font-size: clamp(26px, 4vw, 40px);
  font-weight: 500;
  color: #fff;
  margin-bottom: 0.75rem;
}
.page-hero p { color: var(--b100); font-size: 15px; max-width: 500px; margin: 0; }

.events-list { border-top: 0.5px solid var(--gray-border); }

.event-row {
  display: grid;
  grid-template-columns: 90px 1fr auto;
  align-items: center;
  gap: 1.25rem;
  padding: 1rem;
  margin: 0 -1rem;
  border-bottom: 0.5px solid var(--gray-border);
  text-decoration: none;
  color: inherit;
  border-radius: 4px;
  transition: background 0.12s;
}
.event-row:hover { background: var(--b50); }
.event-row:hover .event-title { color: var(--b600); }
.event-row:hover .event-arrow { transform: translateX(3px); }

.event-date { font-size: 13px; color: var(--gray-secondary); }
.event-type {
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--b600);
  margin-bottom: 0.2rem;
}
.event-title { font-size: 15px; font-weight: 500; color: var(--b900); }
.event-location { font-size: 12px; color: var(--gray-secondary); margin-top: 0.2rem; }

.event-aside { display: flex; flex-direction: column; align-items: flex-end; gap: 0.4rem; }

.badge-upcoming {
  font-size: 11px;
  color: var(--b800);
  background: var(--b50);
  border: 1px solid var(--b100);
  border-radius: 100px;
  padding: 0.2rem 0.6rem;
  white-space: nowrap;
}
.event-arrow { color: var(--b400); font-size: 16px; transition: transform 0.12s; }

@media (max-width: 480px) {
  .event-row { grid-template-columns: 1fr auto; }
  .event-date { display: none; }
}
</style>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('#event-filters .pill');
  const rows = document.querySelectorAll<HTMLElement>('#events-list .event-row');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      rows.forEach(row => {
        const types = (row.dataset.types || '').split(',');
        row.style.display = (filter === 'all' || types.includes(filter!)) ? '' : 'none';
      });
    });
  });
</script>
