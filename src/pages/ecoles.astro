---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allSchools = await getCollection('schools');
const schools = allSchools.filter(s => !s.data.archived);
const archived = allSchools.filter(s => s.data.archived);
const marseille = schools.filter(s => s.data.city.includes('marseille'));
const nice = schools.filter(s => s.data.city.includes('nice'));

function shuffle<T>(arr: T[]): T[] {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const all = shuffle(schools);
---
<Base title="Écoles" description="Les 9 écoles du numérique partenaires de Code4Sud en région Sud — Marseille et Nice.">
  <div class="page-hero">
    <div class="container">
      <div class="hero-tag">
        <span class="tag-line"></span>
        Réseau Code4Sud
      </div>
      <h1>Les écoles partenaires</h1>
      <p>{schools.length} écoles du numérique à Marseille ({marseille.length}) et Nice ({nice.length}) — bootcamps, formations RNCP, filières inclusives.</p>
    </div>
  </div>

  <section class="page-section">
    <div class="container">
      <div class="pill-filters">
        <button class="pill active" data-filter="all">Toutes les villes</button>
        <button class="pill" data-filter="marseille">Marseille ({marseille.length})</button>
        <button class="pill" data-filter="nice">Nice ({nice.length})</button>
        {archived.length > 0 && (
          <button class="pill pill--archive" data-filter="archive">Archives ({archived.length})</button>
        )}
      </div>

      <div class="schools-grid" id="schools-grid">
        {all.map((school) => (
          <a
            href={school.data.site}
            target="_blank"
            rel="noopener"
            class="school-card"
            data-cities={school.data.city.join(',')}
            data-archived="false"
          >
            <div class="school-card-header">
              {school.data.city.map(c => (
                <span class={`city-dot dot--${c}`}></span>
              ))}
              <span class="city-label">{school.data.city.map(c => c === 'marseille' ? 'Marseille' : 'Nice').join(' · ')}</span>
            </div>
            <div class="school-name">{school.data.name}</div>
            <div class="school-desc">{school.data.description}</div>
            <span class="school-link">Voir le site →</span>
          </a>
        ))}
        {archived.map((school) => (
          <a
            href={school.data.site}
            target="_blank"
            rel="noopener"
            class="school-card school-card--archived"
            data-cities={school.data.city.join(',')}
            data-archived="true"
            style="display:none"
          >
            <div class="school-card-header">
              <span class="archive-badge">Ancienne école membre</span>
            </div>
            <div class="school-name">{school.data.name}</div>
            <div class="school-desc">{school.data.description}</div>
            <span class="school-link">Voir le site →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
.page-hero {
  background: var(--b900);
  padding: 3.5rem 0 3rem;
}

.hero-tag {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  color: var(--b200);
  font-size: 13px;
  margin-bottom: 1rem;
}

.tag-line {
  width: 24px;
  height: 1px;
  background: var(--b200);
}

.page-hero h1 {
  font-size: clamp(26px, 4vw, 40px);
  font-weight: 500;
  color: #fff;
  margin-bottom: 0.75rem;
}

.page-hero p {
  color: var(--b100);
  font-size: 15px;
  max-width: 500px;
  margin: 0;
}

.schools-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  border: 0.5px solid var(--gray-border);
  border-radius: 8px;
  overflow: hidden;
}

.school-card {
  display: flex;
  flex-direction: column;
  padding: 1.25rem;
  background: #fff;
  border-right: 0.5px solid var(--gray-border);
  border-bottom: 0.5px solid var(--gray-border);
  text-decoration: none;
  transition: background 0.12s;
}

.school-card:hover {
  background: var(--b50);
}

.school-card:nth-child(3n) {
  border-right: none;
}

.school-card-header {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.city-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot--marseille { background: var(--b400); }
.dot--nice { background: var(--b200); }

.city-label {
  font-size: 11px;
  font-weight: 500;
  color: var(--b600);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.school-name {
  font-size: 15px;
  font-weight: 500;
  color: var(--b900);
  margin-bottom: 0.5rem;
  line-height: 1.3;
}

.school-desc {
  font-size: 13px;
  color: var(--gray-secondary);
  line-height: 1.5;
  flex: 1;
  margin-bottom: 0.75rem;
}

.school-link {
  font-size: 12px;
  color: var(--b600);
}

.school-card--archived {
  opacity: 0.6;
}

.archive-badge {
  font-size: 10px;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--gray-secondary);
  background: var(--gray-light);
  border: 0.5px solid var(--gray-border);
  border-radius: 100px;
  padding: 0.2rem 0.6rem;
}

.pill--archive {
  border-color: var(--gray-border);
  color: var(--gray-secondary);
}

.pill--archive.active {
  background: var(--gray-secondary);
  border-color: var(--gray-secondary);
  color: #fff;
}

@media (max-width: 768px) {
  .schools-grid { grid-template-columns: repeat(2, 1fr); }
  .school-card:nth-child(3n) { border-right: 0.5px solid var(--gray-border); }
  .school-card:nth-child(2n) { border-right: none; }
}

@media (max-width: 480px) {
  .schools-grid { grid-template-columns: 1fr; }
  .school-card { border-right: none; }
}
</style>

<script>
  const pills = document.querySelectorAll<HTMLButtonElement>('.pill-filters .pill');
  const cards = document.querySelectorAll<HTMLElement>('.school-card');

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const filter = pill.dataset.filter;
      cards.forEach(card => {
        const isArchived = card.dataset.archived === 'true';
        if (filter === 'archive') {
          card.style.display = isArchived ? '' : 'none';
        } else {
          if (isArchived) { card.style.display = 'none'; return; }
          const cities = (card.dataset.cities || '').split(',');
          card.style.display = (filter === 'all' || cities.includes(filter)) ? '' : 'none';
        }
      });
    });
  });
</script>
